{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hatchmark",
  "version": "0.1.0",
  "identifier": "com.evanh.hatchmark",
  "build": {
    "beforeDevCommand": "npm --prefix web run dev",
    "beforeBuildCommand": "npm --prefix web run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "web/build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hatchmark",
        "width": 980,
        "height": 680,
        "minWidth": 760,
        "minHeight": 520,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
